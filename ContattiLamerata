<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contatti - UrbanFit</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(to right, #1e1e1e, #444);
            color: white;
            text-align: center;
            margin: 0;
            padding: 0;
        }

        h1 {
            margin-top: 30px;
        }

        form {
            background: white;
            color: black;
            padding: 20px;
            margin: 30px auto;
            width: 320px;
            border-radius: 10px;
            box-shadow: 0 0 10px black;
        }

        input, textarea {
            width: 90%;
            padding: 10px;
            margin-top: 8px;
            border-radius: 5px;
            border: 1px solid #ccc;
        }

        button {
            margin-top: 15px;
            padding: 10px 20px;
            background: black;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background: #333;
        }

        a {
            display: inline-block;
            margin-top: 20px;
            color: #00ccff;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <h1>UrbanFit - Contattaci</h1>
    <p>Scrivici per informazioni sui nostri prodotti streetwear 🔥</p>

    <form>
        <input type="text" name="nome" placeholder="Nome" required>

        <input type="email" name="email" placeholder="Email" required>

        <textarea name="messaggio" rows="5" placeholder="Scrivi il tuo messaggio..." required></textarea>

        <button type="submit">Invia</button>
    </form>

    <a href="index.html">⬅ Torna alla Home</a>

</body>
</html>
